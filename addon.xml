<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.koryotv"
       name="Koryo TV"
       version="1.0.2"
       provider-name="KoryoTV">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Koryo TV</summary>
    <description lang="en_GB">Browse and stream videos from Koryo TV.</description>
    <platform>all</platform>
    <license>Unlicensed</license>
    <assets>
      <icon>resources/media/icon.png</icon>
      <fanart>resources/media/fanart.png</fanart>
    </assets>
    <website>https://koryo.tv</website>
    <news>
    - 1.0.2
    </news>
  </extension>
</addon>
