<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<settings version="1">
    <section id="plugin.video.koryotv" label="Koryo TV">
        <category id="general" label="General">
            <group id="1">

                <setting id="server_mode" type="integer" label="Select Server">
                    <level>0</level>
                    <default>0</default>  <!-- Auto -->
                    <constraints>
                        <options>
                            <option label="Auto - Automatically pick best server">0</option>  <!-- Auto -->
                            <option label="Kosovo Server (PRS)">1</option>  <!-- Kosovo -->
                            <option label="Canada Server (MTR)">2</option>  <!-- Canada -->
                            <option label="Macau Server (MCU)">3</option>  <!-- Macau -->
                            <option label="Japan Server (OSK)">4</option>  <!-- Japan -->
                            <option label="Russia Server (VVO)">5</option>  <!-- Russia -->
                            <option label="South Africa Server (JHB)">6</option>  <!-- South Africa -->
                        </options>
                    </constraints>
                    <control format="string" type="spinner"/>
                </setting>

            </group>
        </category>
    </section>
</settings>
